{
  "name": "email-verifier",
  "version": "1.0.0",
  "description": "Production-ready Email Verification Module with syntax checks, DNS MX lookup, SMTP mailbox verification, typo detection and unit tests",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "cli": "node index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "email",
    "verifier",
    "smtp",
    "validator",
    "dns",
    "mx"
  ],
  "author": "Shreyash Patil",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShreyashPatil530/smtp-email-verifier.git"
  },
  "dependencies": {
    "express": "^4.22.2",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/coverage/"
    ],
    "testTimeout": 15000
  }
}
